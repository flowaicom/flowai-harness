# FlowAI harness e2e testing configuration.
#
# Copy this file to `.env` for local runs. Do not commit real connection
# strings or API keys.

# Required for Neon-backed e2e tests.
FLOWAI_E2E=1
FLOWAI_E2E_NEON_PROJECT_ID=

# Neon branch and role defaults.
FLOWAI_E2E_NEON_ROLE=e2e_owner
FLOWAI_E2E_NEON_PARENT_BRANCH=e2e-base
FLOWAI_E2E_BRANCH_TTL_HOURS=24

# Optional database-name overrides. Leave these unset unless you bootstrapped
# e2e-base with non-default database names.
# FLOWAI_E2E_TARGET_DATABASE=flowai_e2e_target
# FLOWAI_E2E_CATALOG_DATABASE=flowai_e2e_catalog
# FLOWAI_E2E_KV_DATABASE=flowai_e2e_kv
# FLOWAI_E2E_TARGET_SCHEMA=retail

# Local artifact root for generated data-environment files and catalog indexes.
FLOWAI_E2E_RUN_ROOT=.data/e2e

# Print live progress during Neon e2e runs. Set to 0 to restore pytest capture.
FLOWAI_E2E_PROGRESS=1

# Optional live model runs. Leave disabled for deterministic/schema-only e2e.
FLOWAI_E2E_LIVE_LLM=0
FLOWAI_E2E_LIVE_ENRICHMENT=0
ANTHROPIC_API_KEY=
