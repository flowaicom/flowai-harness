dotenv_if_exists .env

# Keep the example package importable for ad hoc commands. Do not prepend
# ../../py-flowai-harness here: the preview install builds the native harness
# extension into ../../.venv, and the source tree may contain stale _internal*.so
# artifacts from a different Python build.
export PYTHONPATH="$(pwd)/src${PYTHONPATH:+:$PYTHONPATH}"
