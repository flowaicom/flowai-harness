{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "baseUrl": "..",
    "paths": {
      "@studio/core": ["./packages/studio-core/dist/index.d.ts"],
      "@studio/core/*": ["./packages/studio-core/dist/*"],
      "@studio/ui": ["./packages/studio-ui/dist/index.d.ts"],
      "@studio/ui/*": ["./packages/studio-ui/dist/*"],
      "@studio/ui/styles.css": ["./packages/studio-ui/dist/styles.css"],
      "@studio/features-chat": ["./packages/studio-features-chat/dist/index.d.ts"],
      "@studio/features-connect": ["./packages/studio-features-connect/dist/index.d.ts"],
      "@studio/features-evals": ["./packages/studio-features-evals/dist/index.d.ts"],
      "@studio/features-tests": ["./packages/studio-features-tests/dist/index.d.ts"]
    },
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": false,
    "declarationMap": false,
    "sourceMap": false
  }
}
